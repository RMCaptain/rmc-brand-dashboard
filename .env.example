# Amazon SP-API Credentials
# Obtain these from Seller Central > Apps & Services > Develop Apps

SP_API_CLIENT_ID=your_client_id_here
SP_API_CLIENT_SECRET=your_client_secret_here
SP_API_REFRESH_TOKEN=your_refresh_token_here
SP_API_SELLER_ID=your_seller_id_here

# Marketplace IDs — use the correct ID(s) for your region
# US:  ATVPDKIKX0DER
# CA:  A2EUQ1WTGCTBG2
# UK:  A1F83G8C2ARO7P
# DE:  A1PA6795UKMFR9
SP_API_MARKETPLACE_IDS=ATVPDKIKX0DER

PORT=3000
