# Normalize line endings: LF in repo, platform-native on checkout
* text=auto eol=lf

*.sh text eol=lf
*.json text eol=lf
*.md text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.css text eol=lf
*.html text eol=lf
*.sql text eol=lf

*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
